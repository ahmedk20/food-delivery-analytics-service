APP_STAGE=dev
PORT=3002
HOST=localhost

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=analytics_service

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_ORDER_EVENTS_EXCHANGE=order-service.events
RABBITMQ_QUEUE=analytics-service.order-events
RABBITMQ_DLX=analytics-service.order-events.dlx
RABBITMQ_DLQ=analytics-service.order-events.dead
RABBITMQ_PREFETCH=10

# JWT (shared with core/order services — verify only)
ACCESS_SECRET=your-access-secret-here

# Core service (RBAC permission lookup)
CORE_SERVICE_URL=http://localhost:3000
CORE_SERVICE_API_KEY=internal-api-key-here

# RBAC cache TTL
RBAC_CACHE_TTL_SEC=300

# Event dedup TTL (days)
EVENT_DEDUP_TTL_DAYS=7

APP_STAGE=dev
PORT=3002
HOST=localhost

MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=analytics_service

RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_ORDER_EVENTS_EXCHANGE=order-service.events

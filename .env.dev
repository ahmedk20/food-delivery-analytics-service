RABBITMQ_DLX=analytics-service.order-events.dlx
RABBITMQ_DLQ=analytics-service.order-events.dead
RABBITMQ_PREFETCH=10

ACCESS_SECRET=dev-secret-change-me

CORE_SERVICE_URL=http://localhost:3000
